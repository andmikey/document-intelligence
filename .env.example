# OpenRouter API key (required for remote model calls)
OPENROUTER_API_KEY=your_api_key_here

# Tuneable parameters
MAX_FILE_SIZE_MB=10
CONFIDENCE_THRESHOLD=0.6

# Multi-agent HITL: confidence below this triggers classifier review checkpoint
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6

# Development posture
# Set LOCAL_DEV_MODE=false and ALLOW_NETWORK_CALLS=true to use real LLM backends.
# Defaults are offline-safe for local development.
LOCAL_DEV_MODE=true
ALLOW_NETWORK_CALLS=false

# Local run log path (one JSONL line per run)
RUN_LOG_PATH=logs/pipeline_runs.jsonl

# LangSmith tracing (optional — tracing is skipped when these are absent)
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_PROJECT=document-intelligence
